{
  "description": "flywheel Telegram notifications — DMs a bot on errors/limits, agent-waiting, and run completion. Dormant until you run /telegram-message; no-ops with no config. Pings are dispatch-gated by default: they fire only around a live /dispatch run in that repo. StopFailure is Claude Code-only (Droid has no error hook); Notification + SessionEnd work on both CLIs.",
  "hooks": {
    "StopFailure": [
      {
        "matcher": "rate_limit|overloaded|authentication_failed|oauth_org_not_allowed|billing_error|invalid_request|model_not_found|server_error|max_output_tokens|unknown",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/skills/telegram-message/scripts/pg_telegram_notify.py\" errors"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "permission_prompt|idle_prompt|agent_needs_input|elicitation_dialog",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/skills/telegram-message/scripts/pg_telegram_notify.py\" waiting"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/skills/telegram-message/scripts/pg_telegram_notify.py\" completions"
          }
        ]
      }
    ]
  }
}
