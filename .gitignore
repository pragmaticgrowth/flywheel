# dependencies
node_modules/
.pnp
.pnp.js

# build output — dist/ is committed so plugin installs work without
# requiring `npm install`; keep tsbuildinfo and the generic build/ out.
build/
*.tsbuildinfo

# logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# environment
.env
.env.local
.env.*.local

# coverage
coverage/
*.lcov
.nyc_output/

# editor / OS
.DS_Store
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
*.swp
*.swo

# misc
.cache/
.tmp/
tmp/

# droid mission debris — when a real mission runs in this cwd with --auto
# high, droid creates mission scaffolding (init.sh, services.yaml, skills/,
# validation/, library/) and may also commit it. We don't want any of that
# in the mcp-do repo. Project-local droid PROFILES (.factory/droids/)
# are still allowed since that's a legitimate droid convention.
.factory/
!.factory/droids/

# plugin-cache artifacts (Claude Code writes these during version bumps)
.orphaned_at

# stray files written by mission features that ran in this cwd
/step1.txt
/step2.txt
/step3.txt
/hello.sh
/hello.ts
